@prefix : <http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/> .

<http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/hasAddress
:hasAddress rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Publisher ;
            rdfs:range :Address .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/hasCategory
:hasCategory rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :BoardGame ;
             rdfs:range :GameCategory .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/hasDesigned
:hasDesigned rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             owl:inverseOf :isDesignedBy ;
             rdfs:domain :Designer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/hasMechanic
:hasMechanic rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :BoardGame ;
             rdfs:range :GameMechanics .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/hasPublished
:hasPublished rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              owl:inverseOf :isPublishedBy ;
              rdfs:domain :Publisher .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/hasType
:hasType rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :BoardGame ;
         rdfs:range :GameType .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/isDesignedBy
:isDesignedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :BoardGame ;
              rdfs:range :Designer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/isExpansionOf
:isExpansionOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain :Expansion ;
               rdfs:range :BoardGame .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/isPartOfSeries
:isPartOfSeries rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdf:type owl:SymmetricProperty ,
                         owl:TransitiveProperty ;
                rdfs:domain :BoardGame ;
                rdfs:range :BoardGame .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/isPublishedBy
:isPublishedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain :BoardGame ;
               rdfs:range :Publisher .


###  http://www.w3.org/2002/07/owl#topObjectProperty
owl:topObjectProperty rdf:type owl:ObjectProperty ,
                               owl:SymmetricProperty .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/birthYear
:birthYear rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :Person ;
           rdfs:range xsd:integer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/city
:city rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdf:type owl:FunctionalProperty ;
      rdfs:domain :Address ;
      rdfs:range xsd:string .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/complexity
:complexity rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :BoardGame ;
            rdfs:range xsd:decimal .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/country
:country rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdf:type owl:FunctionalProperty ;
         rdfs:domain :Address ;
         rdfs:range xsd:string .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/foundedOn
:foundedOn rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :Publisher ;
           rdfs:range xsd:integer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/maxCount
:maxCount rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :playerCount ;
          rdf:type owl:FunctionalProperty ;
          rdfs:domain :BoardGame ;
          rdfs:range xsd:integer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/maxPlayingTime
:maxPlayingTime rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :playingTime ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :BoardGame ;
                rdfs:range xsd:integer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/minCount
:minCount rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :playerCount ;
          rdf:type owl:FunctionalProperty ;
          rdfs:domain :BoardGame ;
          rdfs:range xsd:integer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/minPlayingTime
:minPlayingTime rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :playingTime ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :BoardGame ;
                rdfs:range xsd:integer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/playerCount
:playerCount rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :BoardGame ;
             rdfs:range xsd:integer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/playingTime
:playingTime rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :BoardGame ;
             rdfs:range xsd:integer ;
             rdfs:comment "Measured in minutes" .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/rating
:rating rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdf:type owl:FunctionalProperty ;
        rdfs:domain :BoardGame ;
        rdfs:range xsd:decimal .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/releaseYear
:releaseYear rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :BoardGame ;
             rdfs:range xsd:integer .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/street
:street rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdf:type owl:FunctionalProperty ;
        rdfs:domain :Address ;
        rdfs:range xsd:string .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/suggestedAge
:suggestedAge rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain :BoardGame ;
              rdfs:range xsd:integer .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/Address
:Address rdf:type owl:Class .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/BoardGame
:BoardGame rdf:type owl:Class .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/CompetitiveGame
:CompetitiveGame rdf:type owl:Class ;
                 rdfs:subClassOf :BoardGame ;
                 owl:disjointWith :CooperativeGame .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/CooperativeGame
:CooperativeGame rdf:type owl:Class ;
                 rdfs:subClassOf :BoardGame .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/Designer
:Designer rdf:type owl:Class ;
          rdfs:subClassOf :Person .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/Expansion
:Expansion rdf:type owl:Class ;
           rdfs:subClassOf :BoardGame .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/GameCategory
:GameCategory rdf:type owl:Class .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/GameMechanics
:GameMechanics rdf:type owl:Class .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/GameType
:GameType rdf:type owl:Class .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/Person
:Person rdf:type owl:Class .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/Publisher
:Publisher rdf:type owl:Class .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/SemiCooperativeGame
:SemiCooperativeGame rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :CooperativeGame
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :hasMechanic ;
                                                                  owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                       owl:oneOf ( :HiddenTraitor
                                                                                                   :PlayerElimination
                                                                                                 )
                                                                                     ]
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf :BoardGame .


###  http://www.semanticweb.org/nikolay/ontologies/2025/11/board-game-ontology/SoloFriendlyGame
:SoloFriendlyGame rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :BoardGame
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :minCount ;
                                                               owl:hasValue 1
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf :BoardGame .


